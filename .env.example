# Supabase — daekwang-sso 프로젝트의 briefing 스키마 사용 (브리핑 전용 프로젝트는 폐기)
# (Dashboard → daekwang-sso → Project Settings → API)
# - NEXT_PUBLIC_SUPABASE_URL: daekwang-sso 프로젝트 URL (아래 DAEKWANG_SSO_URL 과 반드시 동일)
# - SUPABASE_SERVICE_ROLE_KEY: daekwang-sso 의 service_role 키 (앱은 db.schema='briefing' 로만 접근)
# - NEXT_PUBLIC_SUPABASE_ANON_KEY: 앱 미사용(레거시). 브리핑 데이터는 anon 접근 불가.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 포털 SSO 게이트 (middleware.ts) — daekwang-sso 토큰 검증
# - DAEKWANG_SSO_URL: 위 NEXT_PUBLIC_SUPABASE_URL 과 같은 daekwang-sso 프로젝트 URL
# - DAEKWANG_SSO_ANON_KEY: daekwang-sso anon 키 (/auth/v1/user 인트로스펙션)
# - SSO_SESSION_SECRET: sso_session 쿠키 서명용 임의 문자열
# - PORTAL_URL: 미인증 시 리다이렉트할 포털 URL
DAEKWANG_SSO_URL=
DAEKWANG_SSO_ANON_KEY=
SSO_SESSION_SECRET=
PORTAL_URL=

# 사이트 URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 네이버 검색 API (https://developers.naver.com → 애플리케이션 등록 → 사용 API "검색")
# - 미설정 시 다음(Daum) 뉴스만으로 동작. 설정하면 네이버+다음을 함께 수집.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# AI 프로바이더 API 키 — 무료/유료 슬롯별로 입력. 설정한 슬롯만 화면에 노출된다.
# (둘 중 하나만 채워도 됨. 예: Mistral은 무료만, Grok은 유료만)
# - Gemini: Google AI Studio. 무료=빌링 미설정 프로젝트 키 / 유료=빌링 설정 프로젝트 키
GEMINI_API_KEY_FREE=
GEMINI_API_KEY_PAID=
# - Mistral: https://console.mistral.ai (OpenAI 호환)
MISTRAL_API_KEY_FREE=
MISTRAL_API_KEY_PAID=
# - xAI Grok: https://console.x.ai (OpenAI 호환, 실질 유료)
XAI_API_KEY_FREE=
XAI_API_KEY_PAID=

# 한국은행 ECOS API 키 (https://ecos.bok.or.kr → 인증키 신청)
# - 설정 시 11대 금리·심리 지표가 모든 브리핑에 자동 통합 (고정값이라 화면 입력칸 없음)
ECOS_API_KEY=

# 관리자 페이지 비밀번호 + 쿠키 서명 키
# - ADMIN_PASSWORD: 본인이 쓸 비밀번호 (예: 강력한 임의 문자열)
# - ADMIN_SESSION_SECRET: 32자+ 임의 문자열 (PowerShell:
#   [Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32)))
ADMIN_PASSWORD=CHANGEME
ADMIN_SESSION_SECRET=CHANGEME_RANDOM_32_BYTES

# 그 외 사용자 입력:
# - Gmail/앱 비밀번호: 이메일 발송 모달에서 매번 입력 (서버 저장 안 함)
